# API
APP_ENV=development
SECRET_KEY=change-me-in-production
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000

# Storage
STORAGE_DIR=./storage
DATABASE_URL=sqlite+aiosqlite:///./storage/rage.db

# Replay
REPLAY_ENABLED=true
REPLAY_MODE=websocket       # websocket | mss
REPLAY_BUFFER_SECONDS=35
REPLAY_FPS=10
REPLAY_OUTPUT_FPS=10

# Privacy
PRIVACY_SCRUB_PII=true
PRIVACY_BLUR_SCREENSHOTS=false

# Alerts — set to enable
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
GENERIC_WEBHOOK_URL=
WEBHOOK_COOLDOWN_SECONDS=60
